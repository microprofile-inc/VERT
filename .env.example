# The hostname used for analytics tracking
PUB_HOSTNAME=formatcube.com

# Plausible Analytics instance (empty = disabled)
PUB_PLAUSIBLE_URL=

# Application environment: "production", "development", or "nightly"
PUB_ENV=development

# vertd daemon URL (empty = disabled, video conversion is hidden)
PUB_VERTD_URL=

# Disable all external requests (vertd, Stripe, Plausible, etc.)
PUB_DISABLE_ALL_EXTERNAL_REQUESTS=true

# Disable failure blocking for video conversions
PUB_DISABLE_FAILURE_BLOCKS=false

# Stripe donation settings (empty = disabled)
PUB_DONATION_URL=
PUB_STRIPE_KEY=
